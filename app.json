{
  "expo": {
    "name": "JanSetu",
    "slug": "jansetu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jansetu",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jansetu.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "JanSetu needs microphone access for voice complaints",
        "NSLocationWhenInUseUsageDescription": "JanSetu needs location to geo-tag hazard reports",
        "NSCameraUsageDescription": "JanSetu needs camera access to capture hazard photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.jansetu.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "JanSetu needs photo access to attach images to complaints"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "JanSetu needs location to geo-tag hazard reports"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9e69bdbb-977b-42b2-adf8-03bc5e1e87f0"
      }
    }
  }
}
